/* Test 6: Start-Stop-Start cycle works */
ZTEST({{ zephlet_name_lower }}_integration, test_lifecycle_cycle)
{
	/* Start */
	zlet_{{ zephlet_name_lower }}_start(303, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No start status");
	zassert_true(last_report.status.is_running, "Should be running");
	zassert_true(last_has_result, "Should have context");
	zassert_equal(last_result.correlation_id, 303, "Correlation ID mismatch");
	zassert_equal(last_result.return_code, 0, "Expected success");

	/* Stop */
	zlet_{{ zephlet_name_lower }}_stop(0, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No stop status");
	zassert_false(last_report.status.is_running, "Should be stopped");

	/* Start again */
	zlet_{{ zephlet_name_lower }}_start(304, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No restart status");
	zassert_true(last_report.status.is_running, "Should be running again");
	zassert_true(last_has_result, "Should have context");
	zassert_equal(last_result.correlation_id, 304, "Correlation ID mismatch");
	zassert_equal(last_result.return_code, 0, "Expected success");
}

