#include <zephyr/ztest.h>
#include <zephyr/kernel.h>
#include "zlet_{{ zephlet_name_lower }}_interface.h"

/* Counter for callbacks */
static int report_count = 0;
static struct {{ zephlet_name_lower }}_report last_report;
static struct zephlet_result last_result;
static bool last_has_result;

K_SEM_DEFINE(report_sem, 0, 10);

/* Real async listener - no mocking! */
static void {{ zephlet_name_lower }}_report_listener(const struct zbus_channel *chan)
{
	const struct {{ zephlet_name_lower }}_report *msg = zbus_chan_const_msg(chan);

	if (chan == &chan_zlet_{{ zephlet_name_lower }}_report) {
		memcpy(&last_report, msg, sizeof(last_report));
		last_has_result = msg->has_result;
		if (msg->has_result) {
			last_result = msg->result;
		}
		report_count++;
		k_sem_give(&report_sem);
	}
}

ZBUS_LISTENER_DEFINE(test_lis, {{ zephlet_name_lower }}_report_listener);
ZBUS_CHAN_ADD_OBS(chan_zlet_{{ zephlet_name_lower }}_report, test_lis, 2);

/* Reset between tests */
static void reset(void *fixture)
{
	ARG_UNUSED(fixture);

	/* Stop the zephlet if running */
	zlet_{{ zephlet_name_lower }}_stop(0, K_MSEC(100));
	k_sem_take(&report_sem, K_MSEC(100));  /* Consume stop report */

	report_count = 0;
	memset(&last_report, 0, sizeof(last_report));
	memset(&last_result, 0, sizeof(last_result));
	last_has_result = false;
	k_sem_reset(&report_sem);
}

ZTEST_SUITE({{ zephlet_name_lower }}_integration, NULL, NULL, reset, NULL, NULL);

/* Test 1: Start publishes status */
ZTEST({{ zephlet_name_lower }}_integration, test_start)
{
	zlet_{{ zephlet_name_lower }}_start(123, K_MSEC(100));

	/* Wait for listener callback */
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No status report received");

	zassert_equal(last_report.which_{{ zephlet_name_lower }}_report_tag, {{ zephlet_name_upper }}_REPORT_STATUS_TAG,
		      "Expected status report");
	zassert_true(last_report.status.is_running, "{{ zephlet_name_lower }} should be running");
	zassert_equal(report_count, 1, "Expected 1 report");
	zassert_true(last_has_result, "Should have context");
	zassert_equal(last_result.correlation_id, 123, "Correlation ID mismatch");
	zassert_equal(last_result.return_code, 0, "Expected success");
}

/* Test 2: Stop stops zephlet */
ZTEST({{ zephlet_name_lower }}_integration, test_stop)
{
	/* Start zephlet */
	zlet_{{ zephlet_name_lower }}_start(0, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No start status");

	/* Stop zephlet */
	zlet_{{ zephlet_name_lower }}_stop(301, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No stop status");
	zassert_equal(last_report.which_{{ zephlet_name_lower }}_report_tag, {{ zephlet_name_upper }}_REPORT_STATUS_TAG,
		      "Expected status report");
	zassert_false(last_report.status.is_running, "{{ zephlet_name_lower }} should be stopped");
	zassert_true(last_has_result, "Should have context");
	zassert_equal(last_result.correlation_id, 301, "Correlation ID mismatch");
	zassert_equal(last_result.return_code, 0, "Expected success");
}

/* Test 3: Get status returns current state */
ZTEST({{ zephlet_name_lower }}_integration, test_get_status)
{
	/* Start zephlet first */
	zlet_{{ zephlet_name_lower }}_start(0, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No start status");

	/* Reset counter */
	report_count = 0;

	/* Get status */
	zlet_{{ zephlet_name_lower }}_get_status(302, K_MSEC(100));
	zassert_ok(k_sem_take(&report_sem, K_SECONDS(1)), "No status from get");
	zassert_equal(last_report.which_{{ zephlet_name_lower }}_report_tag, {{ zephlet_name_upper }}_REPORT_STATUS_TAG,
		      "Expected status report");
	zassert_true(last_report.status.is_running, "Should be running");
	zassert_true(last_has_result, "Should have context");
	zassert_equal(last_result.correlation_id, 302, "Correlation ID mismatch");
	zassert_equal(last_result.return_code, 0, "Expected success");
}

