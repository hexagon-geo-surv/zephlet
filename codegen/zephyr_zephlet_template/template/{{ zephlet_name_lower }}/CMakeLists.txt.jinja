if(CONFIG_ZEPHLET_{{ zephlet_name_upper }})
    # Generate full proto from schema + base proto → build dir
    zephyr_zephlet_generate_proto(zlet_{{ zephlet_name_lower }}
        "${ZEPHYR_SHARED_ZEPHLET_MODULE_DIR}/zephlet.proto"
        "${ZEPHYR_ZLET_{{ zephlet_name_upper }}_MODULE_DIR}/zlet_{{ zephlet_name_lower }}.proto")

    # Register generated proto for nanopb
    set_property(GLOBAL APPEND PROPERTY PROTO_FILES_LIST
        "${zlet_{{ zephlet_name_lower }}_GENERATED_PROTO}")

    # Auto-generate zephlet infrastructure from generated proto
    zephyr_zephlet_generate(zlet_{{ zephlet_name_lower }} "${zlet_{{ zephlet_name_lower }}_GENERATED_PROTO}")
    add_dependencies(zlet_{{ zephlet_name_lower }}_codegen zlet_{{ zephlet_name_lower }}_proto_gen)

    # Expose build directory globally for zephlet headers
    zephyr_include_directories("${CMAKE_CURRENT_BINARY_DIR}")

    # Interface library with include paths
    zephyr_interface_library_named(zlet_{{ zephlet_name_lower }})
    target_include_directories(zlet_{{ zephlet_name_lower }} INTERFACE
        ${ZEPHYR_ZLET_{{ zephlet_name_upper }}_MODULE_DIR}           # Source (for .c)
        "${CMAKE_CURRENT_BINARY_DIR}"               # Build (for .h/.c/.priv.h)
        "${CMAKE_BINARY_DIR}/zephlets"              # Build parent (for .pb.h)
    )

    # Add sources: generated (build) + implementation (source)
    zephyr_library()
    zephyr_library_sources(
        ${{ "{" }}zlet_{{ zephlet_name_lower }}_GENERATED_C{{ "}" }}
        ${ZEPHYR_ZLET_{{ zephlet_name_upper }}_MODULE_DIR}/zlet_{{ zephlet_name_lower }}.c
    )

    add_dependencies(${ZEPHYR_CURRENT_LIBRARY} zlet_{{ zephlet_name_lower }}_codegen)
    zephyr_library_link_libraries(zlet_{{ zephlet_name_lower }})
endif()
