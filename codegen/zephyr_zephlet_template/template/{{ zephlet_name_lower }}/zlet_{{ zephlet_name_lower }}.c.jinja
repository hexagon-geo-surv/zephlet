static int start(struct zlet_{{ zephlet_name_lower }}_context *ctx)
{
	struct zlet_{{ zephlet_name_lower }}_data *data = ctx->zephlet->data;
	int ret = 0;

	K_SPINLOCK(&data->lock) {
		if (!data->status.is_ready) {
			ret = -ENODEV;
		} else if (data->status.is_running) {
			ret = -EALREADY;
		} else {
			data->status.is_running = true;
		}
		ctx->response.status = data->status;
	}

	/* TODO: Start zephlet resources (timers, threads, etc.) */

	return ret;
}

static int stop(struct zlet_{{ zephlet_name_lower }}_context *ctx)
{
	struct zlet_{{ zephlet_name_lower }}_data *data = ctx->zephlet->data;
	int ret = 0;

	K_SPINLOCK(&data->lock) {
		if (!data->status.is_running) {
			ret = -EALREADY;
		} else {
			data->status.is_running = false;
		}
		ctx->response.status = data->status;
	}

	/* TODO: Stop zephlet resources (timers, threads, etc.) */

	return ret;
}

