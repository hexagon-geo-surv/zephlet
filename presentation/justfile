# Zephlet Presentation Build Automation

# Build the presentation PDF
build:
    typst compile main.typ

# Watch for changes and rebuild automatically (using tinymist LSP)
watch:
    typst watch main.typ

# Preview using tinymist (LSP-based preview)
tinymist-preview:
    tinymist preview main.typ

# Clean generated files
clean:
    rm -f main.pdf
